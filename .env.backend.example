# ===============================
# kunxing-blog backend deployment
# copy this file to .env.backend
# ===============================

# --- database / cache ---
MYSQL_ROOT_PASSWORD=change_this_mysql_password
MYSQL_DATABASE=eleven_blog
REDIS_PASSWORD=change_this_redis_password

# --- host upload mount path ---
# Linux example: /data/kunxing-blog/upload_data
UPLOAD_HOST_DIR=./upload_data

# --- jwt ---
JWT_SECRET=replace_with_a_long_random_secret

# --- github oauth (optional) ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# use your Vercel public domain callback URL
GITHUB_OAUTH_REDIRECT_URI=https://your-frontend-domain.vercel.app/oauth/callback

# --- blog owner info (optional) ---
BLOG_OWNER_EMAIL=
BLOG_OWNER_NICKNAME=kunxing
BLOG_OWNER_GITHUB_ID=0

# --- mail (optional) ---
SPRING_MAIL_HOST=smtp.qq.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
